# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# DuckDB binary — rebuilt automatically at app startup from parquet files
data/analytics_database/*.duckdb
data/analytics_database/*.duckdb-wal
data/analytics_database/*.duckdb-shm

# Raw API response cache — rebuilt by build_warehouse.py
data/source_data/

# Ephemeral quality-check logs
data/quality_checks/

# Intermediate standardized tables
data/standardized_data/

# Projection output files
projection_*.json

# Saved projection snapshots (local tracking, never commit)
data/saved_projections/

# Auto-saved session state (local persistence, never commit)
data/session_autosave.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Streamlit secrets (never commit)
.streamlit/secrets.toml

# Env files
.env
.env.local

# Internal dev / Claude session files (never commit)
CLAUDE_PLL_APP_REVISION_PROMPT.md

# Backtest and test outputs (run locally, not needed on Streamlit Cloud)
scripts/test_format.py
